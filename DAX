// 1. Game Timeline (Linear 0-48 minute scale for X-Axis)
Game_Clock_Time = 
VAR PeriodStart = ('shotdata'[PERIOD] - 1) * 12
VAR TimeElapsed = 12 - 'shotdata'[MINUTES_REMAINING]
RETURN PeriodStart + TimeElapsed

// 2. Shot Difficulty Proxy (Weights based on distance and creation)
Momentum_Difficulty = 
VAR ActionFactor = 
    IF(
        CONTAINSSTRING('shotdata'[ACTION_TYPE], "Pullup") || 
        CONTAINSSTRING('shotdata'[ACTION_TYPE], "Step Back") || 
        CONTAINSSTRING('shotdata'[ACTION_TYPE], "Fadeaway"), 
        1.5, 1.0
    )
RETURN 'shotdata'[SHOT_DISTANCE] * ActionFactor

// 3. Situational Impact Score (Weights for game-changing context)
Momentum_Impact = 
VAR Base = 1.0
VAR Is3PT = IF(CONTAINSSTRING('shotdata'[SHOT_TYPE], "3PT"), 0.5, 0)
VAR IsClutch = IF('shotdata'[PERIOD] >= 4 && 'shotdata'[MINUTES_REMAINING] <= 5, 1.0, 0)
RETURN (Base + Is3PT + IsClutch) * 'shotdata'[SHOT_MADE_FLAG]

// 4. Raw Momentum Score (The energy generated by an individual event)
Momentum_Score = 'shotdata'[Momentum_Difficulty] * 'shotdata'[Momentum_Impact]

// 5. Matchup ID (Human-readable game selector)
Matchup_Readable = 
VAR DateYear = LEFT('shotdata'[GAME_DATE], 4)
VAR DateMonth = MID('shotdata'[GAME_DATE], 5, 2)
VAR DateDay = RIGHT('shotdata'[GAME_DATE], 2)
VAR RealDate = DATE(DateYear, DateMonth, DateDay)
VAR FormattedDate = FORMAT(RealDate, "MMM dd, yyyy")
RETURN 'shotdata'[VTM] & " @ " & 'shotdata'[HTM] & " (" & FormattedDate & ")"
// 6. Total Team Momentum (Aggregate energy per team)
Team_Momentum = SUM('shotdata'[Momentum_Score])

// 7. Cumulative Momentum (Running Total for the "Race" Line Chart)
Cumulative_Momentum = 
CALCULATE(
    [Team_Momentum], 
    FILTER(
        ALLSELECTED('shotdata'),
        'shotdata'[Game_Clock_Time] <= MAX('shotdata'[Game_Clock_Time]) &&
        'shotdata'[TEAM_NAME] = MAX('shotdata'[TEAM_NAME])
    )
)

// 8. Net Momentum (The "Heartbeat" delta between the two opponents)
Net_Momentum = 
VAR SelectedTeam = SELECTEDVALUE('shotdata'[TEAM_NAME])
VAR CurrentGame = SELECTEDVALUE('shotdata'[GAME_ID])
VAR TeamMom = [Team_Momentum]
VAR OpponentMom = 
    CALCULATE(
        [Team_Momentum], 
        ALL('shotdata'[TEAM_NAME]), 
        'shotdata'[GAME_ID] = CurrentGame,
        'shotdata'[TEAM_NAME] <> SelectedTeam
    )
RETURN TeamMom - OpponentMom
// 9. Game MVP (Identifies the player with the highest momentum contribution)
Game_MVP = 
VAR TopPlayer = 
    TOPN(
        1, 
        ALLSELECTED('shotdata'[PLAYER_NAME]), 
        CALCULATE(
            SUM('shotdata'[Momentum_Score]), 
            ALL('shotdata'[Game_Clock_Time]) // Ignores specific minute clicks to show game-total MVP
        )
    )
RETURN CONCATENATEX(TopPlayer, 'shotdata'[PLAYER_NAME], ", ")

// 10. Momentum Status Flag (Qualitative status for Gauges and Cards)
Momentum_Status = 
VAR Net = [Net_Momentum]
RETURN
SWITCH(TRUE(),
    Net > 15, "🔥 DOMINATING",
    Net > 5, "📈 GAINING",
    Net < -5, "📉 LOSING",
    Net < -15, "❄️ COLD",
    "Neutral"
)

// 11. Dynamic Chart Title (Informs the user which team is the baseline)
Chart_Title = 
VAR Selected = SELECTEDVALUE('shotdata'[TEAM_NAME], "Selected Team")
RETURN "Momentum Flow Analysis: Positive values favor " & Selected
